amends "package://github.com/jdx/hk/releases/download/v1.25.0/hk@1.25.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.25.0/hk@1.25.0#/Builtins.pkl"

local shared_steps = new Mapping<String, Step> {
    ["check-merge-conflict"] = Builtins.check_merge_conflict
    ["detect-private-key"] = Builtins.detect_private_key
    ["check-added-large-files"] = (Builtins.check_added_large_files) {
        exclude = "crates/strz-grammar/src/parser.c"
    }
    ["check-byte-order-marker"] = Builtins.check_byte_order_marker
    ["check-symlinks"] = Builtins.check_symlinks
    ["mixed-line-ending"] = Builtins.mixed_line_ending
    ["trailing-whitespace"] = Builtins.trailing_whitespace
    ["newlines"] = (Builtins.newlines) {
        exclude = List(
            "crates/strz-grammar/src/grammar.json",
            "crates/strz-grammar/src/node-types.json",
        )
    }
    ["check-executables-have-shebangs"] = Builtins.check_executables_have_shebangs
    ["python-ruff"] = Builtins.ruff
    ["python-ruff-format"] = (Builtins.ruff_format) {
        depends = "python-ruff"
    }
    ["rustfmt"] = (Builtins.rustfmt) {
        glob = List("crates/**/*.rs", "tools/upstream_audit.rs")
    }
    ["cargo-fmt-check"] = new Step {
        glob = List("crates/**/*.rs")
        depends = "rustfmt"
        check = "cargo fmt --all --check"
    }
    ["generate-grammar-artifacts"] = new Step {
        glob = List("crates/strz-grammar/grammar.js")
        stage = List(
            "crates/strz-grammar/src/parser.c",
            "crates/strz-grammar/src/grammar.json",
            "crates/strz-grammar/src/node-types.json",
        )
        exclusive = true
        check = "just generate && git diff --exit-code -- crates/strz-grammar/src/parser.c crates/strz-grammar/src/grammar.json crates/strz-grammar/src/node-types.json"
        fix = "just generate"
    }
    ["shellcheck"] = Builtins.shellcheck
    ["mdformat"] = new Step {
        glob = List("**/*.md", "**/*.markdown")
        stage = "<JOB_FILES>"
        check = "mdformat --check --extensions gfm --extensions gfm_alerts {{ files }}"
        fix = "mdformat --extensions gfm --extensions gfm_alerts {{ files }}"
    }
    ["lychee"] = new Step {
        glob = List("**/*.md", "**/*.markdown")
        depends = "mdformat"
        check = "lychee --no-progress --scheme file --include-fragments --root-dir \"$PWD\" {{ files }}"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = shared_steps
    }
    ["check"] {
        steps = shared_steps
    }
    ["fix"] {
        fix = true
        stash = "git"
        steps = shared_steps
    }
}
